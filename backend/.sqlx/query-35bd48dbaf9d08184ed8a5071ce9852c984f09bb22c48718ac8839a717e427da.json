  "db_name": "SQLite",
  "query": "\n            SELECT \n                u.id, \n                u.email,\n                u.name,\n                u.password_hash,\n                u.role_id,\n                r.name as role_name,\n                u.registration_state_id,\n                s.name as registration_state,\n                u.created_at,\n                u.updated_at\n            FROM user u\n            JOIN user_role r ON u.role_id = r.id\n            JOIN registration_state s ON u.registration_state_id = s.id\n            ORDER BY u.id\n            ",
